@page "/intereses_futuros"
@rendermode InteractiveServer
@inject FrontBlazorTutorial.Services.ApiService Api

@inject FrontBlazorTutorial.Services.SpService Sp

<PageTitle>Intereses Futuros</PageTitle>

<div class="container mt-4">
    <h3>Intereses Futuros</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Interés Futuro</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Interés Futuro" : "Nuevo Interés Futuro")
            </div>
            <div class="card-body">
                <div class="row">
                     <div class="col-md-6 mb-3">
                        <label class="form-label">Docente</label>
                        <select class="form-select" @bind="docente">
                            <option value="0">Seleccione un docente</option>
                            @foreach (var d in registrosForeignKey1)
                            {
                                <option value="@Convert.ToInt32(d["cedula"])">
                                    @d["nombres"]
                                    @d["apellidos"]
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Termino Clave</label>
                        <select class="form-select" @bind="termino_clave">
                            <option value="0">Seleccione un termino clave</option>
                            @foreach (var t in registrosForeignKey2)
                            {
                                    <option value="@t["termino"]">
                                    @t["termino"]
                                    </option>
                            }
                        </select>
                    </div>  
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any() && registrosForeignKey1.Any() && registrosForeignKey2.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Docente</th>
                    <th>Termino Clave</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                        <tr>
                            <td>
                                @{
                                    var docenteId = Convert.ToInt32(reg["docente"]);
                                    var docenteInfo = registrosForeignKey1
                                        .FirstOrDefault(d => Convert.ToInt32(d["cedula"]) == docenteId);
                                }
                                @((docenteInfo != null)
                                    ? $"{docenteInfo["nombres"]} {docenteInfo["apellidos"]}"
                                    : reg["docente"])
                            </td>
                            <td>@reg["termino_clave"]</td>
                            <td>
                                <button class="btn btn-warning btn-sm me-1"
                                        @onclick="() => EditarRegistro(reg)">Editar</button>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla intereses_futuros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    
    private List<Dictionary<string, object?>> registrosForeignKey1 = new();//los de docente
    private List<Dictionary<string, object?>> registrosForeignKey2 = new();//los de termino_clave

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    
    // Campos del formulario
    private int docente = 0;
    private string termino_clave = string.Empty;

    private int docente_viejo = 0;

    private string termino_clave_viejo = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("intereses_futuros", limite);
        registrosForeignKey1 = await Api.ListarAsync("docente");
        registrosForeignKey2 = await Api.ListarAsync("termino_clave");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        docente = 0;
        termino_clave = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        docente_viejo = Convert.ToInt32(reg["docente"] ?? 0);
        termino_clave_viejo = reg["termino_clave"]?.ToString() ?? "";
        docente = docente_viejo;
        termino_clave = termino_clave_viejo;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["docente"] = docente,
            ["termino_clave"] = termino_clave
        };

        if (editando)
        {
            var parametros = new Dictionary<string, object?>
            {
                ["docente_nuevo"] = docente,
                ["termino_clave_nuevo"] = termino_clave,
                ["docente_viejo"] = docente_viejo,
                ["termino_clave_viejo"] = termino_clave_viejo
            };
            var (ok, _, msg) = await Sp.EjecutarSpAsync("sp_actualizar_intereses_futuros", parametros);
            exito = ok;
            mensaje = ok ? "Actualización exitosa." : $"Error: {msg}";
        }
        else
        {
            var resultado = await Api.CrearAsync("intereses_futuros", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int docente = Convert.ToInt32(reg["docente"]);
        string term = reg["termino_clave"]?.ToString() ?? "";   

        var parametros = new Dictionary<string, object?>
        {
            ["docente"] = docente,
            ["termino_clave"] = term
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("sp_eliminar_intereses_futuros", parametros);
        exito = ok;
        mensaje = ok ? "Eliminación exitosa." : $"Error: {msg}";

        if (exito)
        {
            await CargarRegistros();
        }
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}
