@page "/experiencia"
@rendermode InteractiveServer
@inject FrontBlazorTutorial.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Experiencias</PageTitle>

<div class="container mt-4">
    <h3>Experiencias</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Experiencia</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Experiencia" : "Nueva Experiencia")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Docente</label>
                        <select class="form-select" @bind="campoDocente">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var doc in docentes)
                            {
                                <option value="@doc["cedula"]">@doc["nombres"] @doc["apellidos"] (@doc["cedula"])</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre del Cargo</label>
                        <input class="form-control" @bind="campoNombreCargo" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Institucion</label>
                        <input class="form-control" @bind="campoInstitucion" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" @bind="campoTipo">
                            <option value="">-- Seleccione --</option>
                            <option value="Académica">Académica</option>
                            <option value="Administrativa">Administrativa</option>
                            <option value="Profesional">Profesional</option>
                            <option value="Investigativa">Investigativa</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date" @bind="campoFechaFin" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Cargo</th>
                    <th>Institucion</th>
                    <th>Tipo</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Docente</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre_cargo"]</td>
                        <td>@reg["institucion"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@FormatearFecha(reg["fecha_inicio"]?.ToString())</td>
                        <td>@FormatearFecha(reg["fecha_fin"]?.ToString())</td>
                        <td>@ObtenerNombreDocente(reg["docente"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron experiencias.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> docentes = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int idEditar = 0;

    private int campoDocente = 0;
    private string campoNombreCargo = string.Empty;
    private string campoInstitucion = string.Empty;
    private string campoTipo = string.Empty;
    private DateOnly? campoFechaInicio;
    private DateOnly? campoFechaFin;

    protected override async Task OnInitializedAsync()
    {
        docentes = await Api.ListarAsync("docente");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("experiencia");
        cargando = false;
    }

    private string ObtenerNombreDocente(string? cedula)
    {
        if (string.IsNullOrEmpty(cedula)) return "—";
        var doc = docentes.FirstOrDefault(d => d["cedula"]?.ToString() == cedula);
        return doc != null ? $"{doc["nombres"]} {doc["apellidos"]}" : cedula;
    }

    private string FormatearFecha(string? fecha)
    {
        if (string.IsNullOrEmpty(fecha)) return "—";
        return DateTime.TryParse(fecha, out DateTime f) ? f.ToString("yyyy-MM-dd") : fecha;
    }

    private async void NuevoRegistro()
    {
        editando = false;
        campoDocente = 0;
        campoNombreCargo = string.Empty;
        campoInstitucion = string.Empty;
        campoTipo = string.Empty;
        campoFechaInicio = null;
        campoFechaFin = null;
        docentes = await Api.ListarAsync("docente");
        mostrarFormulario = true;
        mensaje = string.Empty;
        StateHasChanged();
    }

    private async void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        idEditar = int.TryParse(reg["id"]?.ToString(), out int id) ? id : 0;
        campoDocente = int.TryParse(reg["docente"]?.ToString(), out int d) ? d : 0;
        campoNombreCargo = reg["nombre_cargo"]?.ToString() ?? "";
        campoInstitucion = reg["institucion"]?.ToString() ?? "";
        campoTipo = reg["tipo"]?.ToString() ?? "";
        campoFechaInicio = DateTime.TryParse(reg["fecha_inicio"]?.ToString(), out DateTime fi) ? DateOnly.FromDateTime(fi) : null;
        campoFechaFin = DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime ff) ? DateOnly.FromDateTime(ff) : null;
        docentes = await Api.ListarAsync("docente");
        mostrarFormulario = true;
        mensaje = string.Empty;
        StateHasChanged();
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nombre_cargo"] = campoNombreCargo,
            ["institucion"] = campoInstitucion,
            ["tipo"] = campoTipo,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd"),
            ["docente"] = campoDocente
        };

        if (editando)
        {
            var confirmar = await JS.InvokeAsync<bool>("confirm", "¿Está seguro de actualizar la experiencia?");
            if (!confirmar) return;
            var resultado = await Api.ActualizarAsync("experiencia", "id", idEditar.ToString(), datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("experiencia", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["id"]?.ToString() ?? "";
        var confirmar = await JS.InvokeAsync<bool>("confirm", "¿Está seguro de eliminar esta experiencia?");
        if (!confirmar) return;

        var resultado = await Api.EliminarAsync("experiencia", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito) await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}