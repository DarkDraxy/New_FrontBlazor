@page "/estudio-ac"
@rendermode InteractiveServer
@inject FrontBlazorTutorial.Services.ApiService Api
@inject FrontBlazorTutorial.Services.SpService Sp

<div class="container mt-4">
    <h3>Asociación de Estudios y Áreas</h3>

    @if (mostrarFormulario)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="row">
                    @* SELECT 1: ESTUDIOS REALIZADOS *@
                    <div class="col-md-6 mb-3">
                        <label>Seleccione el Estudio</label>
                        <select class="form-select" @bind="estudio_i">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var e in listaEstudios) {
                                <option value="@e["id"]">@e["titulo"]</option>
                            }
                        </select>
                    </div>

                    @* SELECT 2: ÁREA DE CONOCIMIENTO *@
                    <div class="col-md-6 mb-3">
                        <label>Seleccione el Área</label>
                        <select class="form-select" @bind="area_i">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var a in listaAreas) {
                                <option value="@a["id"]">@a["area"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success" @onclick="Guardar">Asociar</button>
                <button class="btn btn-secondary" @onclick="() => mostrarFormulario = false">Cancelar</button>
            </div>
        </div>
    }
    else {
        <button class="btn btn-primary mb-3" @onclick="() => mostrarFormulario = true">Nueva Asociación</button>
    }

    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID Estudio</th>
                <th>ID Área</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reg in registros) {
                <tr>
                    <td>@reg["estudio"]</td>
                    <td>@reg["area_conocimiento"]</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(reg)">Desvincular</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> listaEstudios = new();
    private List<Dictionary<string, object?>> listaAreas = new();
    private bool mostrarFormulario = false;
    private int estudio_i, area_i;

    protected override async Task OnInitializedAsync() {
        await Cargar();
        listaEstudios = await Api.ListarAsync("estudios_realizados");
        listaAreas = await Api.ListarAsync("area_conocimiento");
    }

    private async Task Cargar() {
        registros = await Api.ListarAsync("estudio_ac");
    }

    private async Task Guardar() {
        var p = new Dictionary<string, object?> { ["estudio"] = estudio_i, ["area_conocimiento"] = area_i };
        var res = await Sp.EjecutarSpAsync("sp_InsertarEstudioAC", p);
        if (res.exito) { mostrarFormulario = false; await Cargar(); }
    }

    private async Task Eliminar(Dictionary<string, object?> reg) {
        var p = new Dictionary<string, object?> { ["estudio"] = reg["estudio"], ["area_conocimiento"] = reg["area_conocimiento"] };
        await Sp.EjecutarSpAsync("sp_EliminarEstudioAC", p);
        await Cargar();
    }
}
