@page "/"
@inject FrontBlazorTutorial.Services.ApiService Api
@inject FrontBlazorTutorial.Services.AuthService Auth

<PageTitle>CRUD Facturas</PageTitle>

<div>
    <h1>Bienvenido a CRUD Facturas</h1>
    <p class="lead">
        Hola @(Auth.NombreUsuario ?? Auth.Usuario ?? "usuario"), usa el menu superior para navegar a las tablas que tienes habilitadas.
    </p>

    @if (diagnostico != null)
    {
        <div class="card mt-4">
            <div class="card-header">
                <span class="status-dot status-dot-success"></span>
                Conexion activa
            </div>
            <div class="card-body">
                <dl style="display:grid; grid-template-columns: 160px 1fr; gap:8px 16px; margin:0;">
                    @if (diagnostico.ContainsKey("proveedor"))
                    {
                        <dt class="text-muted">Proveedor</dt>
                        <dd style="margin:0;">
                            <span class="badge">@diagnostico["proveedor"]</span>
                        </dd>
                    }
                    @if (diagnostico.ContainsKey("baseDatos"))
                    {
                        <dt class="text-muted">Base de datos</dt>
                        <dd style="margin:0;"><strong>@diagnostico["baseDatos"]</strong></dd>
                    }
                    @if (diagnostico.ContainsKey("version"))
                    {
                        <dt class="text-muted">Version</dt>
                        <dd style="margin:0; font-size:13px;">
                            @(diagnostico["version"].Length > 80 ? diagnostico["version"][..80] + "..." : diagnostico["version"])
                        </dd>
                    }
                    @if (diagnostico.ContainsKey("direccionIP"))
                    {
                        <dt class="text-muted">Servidor</dt>
                        <dd style="margin:0;">
                            @diagnostico["direccionIP"]@if (diagnostico.ContainsKey("puerto")){<text>:@diagnostico["puerto"]</text>}
                        </dd>
                    }
                    @if (diagnostico.ContainsKey("usuarioConectado"))
                    {
                        <dt class="text-muted">Usuario</dt>
                        <dd style="margin:0;">@diagnostico["usuarioConectado"]</dd>
                    }
                </dl>
            </div>
        </div>
    }
    else if (cargado)
    {
        <div class="card mt-4">
            <div class="card-header" style="border-left-color: var(--error) !important;">
                <span class="status-dot status-dot-error"></span>
                Sin conexion
            </div>
            <div class="card-body">
                <p class="text-muted" style="margin:0;">
                    No se pudo obtener informacion de conexion de la API.
                </p>
            </div>
        </div>
    }
</div>

@code {
    private Dictionary<string, string>? diagnostico;
    private bool cargado;

    protected override async Task OnInitializedAsync()
    {
        diagnostico = await Api.ObtenerDiagnosticoAsync();
        cargado = true;
    }
}