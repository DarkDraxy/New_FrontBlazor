@inject FrontBlazorTutorial.Services.AuthService _auth

<MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Home">
    Home
</MudButton>

@if (PermiteAlguna("/usuario", "/rol", "/ruta"))
{
    <MudMenu Label="Seguridad" Color="Color.Inherit" Variant="Variant.Text" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
        @if (_auth.TieneAcceso("/usuario")) { <MudMenuItem Href="/usuario">Usuario</MudMenuItem> }
        @if (_auth.TieneAcceso("/rol")) { <MudMenuItem Href="/rol">Rol</MudMenuItem> }
        @if (_auth.TieneAcceso("/ruta")) { <MudMenuItem Href="/ruta">Ruta</MudMenuItem> }
    </MudMenu>
}

@if (PermiteAlguna("/empresa", "/persona", "/cliente", "/vendedor", "/producto", "/factura"))
{
    <MudMenu Label="Negocio" Color="Color.Inherit" Variant="Variant.Text" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
        @if (_auth.TieneAcceso("/empresa")) { <MudMenuItem Href="/empresa">Empresa</MudMenuItem> }
        @if (_auth.TieneAcceso("/persona")) { <MudMenuItem Href="/persona">Persona</MudMenuItem> }
        @if (_auth.TieneAcceso("/cliente")) { <MudMenuItem Href="/cliente">Cliente</MudMenuItem> }
        @if (_auth.TieneAcceso("/vendedor")) { <MudMenuItem Href="/vendedor">Vendedor</MudMenuItem> }
        @if (_auth.TieneAcceso("/producto")) { <MudMenuItem Href="/producto">Producto</MudMenuItem> }
        @if (_auth.TieneAcceso("/factura")) { <MudMenuItem Href="/factura">Factura</MudMenuItem> }
    </MudMenu>
}

@if (PermiteAlguna("/docente", "/experiencia", "/evaluacion-docente", "/apoyo-profesoral", "/reconocimiento", "/Red_Docente"))
{
    <MudMenu Label="Docencia" Color="Color.Inherit" Variant="Variant.Text" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
        @if (_auth.TieneAcceso("/docente")) { <MudMenuItem Href="/docente">Docentes</MudMenuItem> }
        @if (_auth.TieneAcceso("/experiencia")) { <MudMenuItem Href="/experiencia">Experiencias</MudMenuItem> }
        @if (_auth.TieneAcceso("/evaluacion-docente")) { <MudMenuItem Href="/evaluacion-docente">Evaluaciones</MudMenuItem> }
        @if (_auth.TieneAcceso("/apoyo-profesoral")) { <MudMenuItem Href="/apoyo-profesoral">Apoyo Profesoral</MudMenuItem> }
        @if (_auth.TieneAcceso("/reconocimiento")) { <MudMenuItem Href="/reconocimiento">Reconocimientos</MudMenuItem> }
        @if (_auth.TieneAcceso("/Red_Docente")) { <MudMenuItem Href="/Red_Docente">Red Docente</MudMenuItem> }
    </MudMenu>
}

@if (PermiteAlguna("/linea-investigacion", "/red", "/area-conocimiento", "/estudios-realizados", "/estudio-ac", "/beca", "/intereses_futuros", "/termino_clave"))
{
    <MudMenu Label="Academico" Color="Color.Inherit" Variant="Variant.Text" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
        @if (_auth.TieneAcceso("/linea-investigacion")) { <MudMenuItem Href="/linea-investigacion">Lineas de Investigacion</MudMenuItem> }
        @if (_auth.TieneAcceso("/red")) { <MudMenuItem Href="/red">Red</MudMenuItem> }
        @if (_auth.TieneAcceso("/area-conocimiento")) { <MudMenuItem Href="/area-conocimiento">Areas de Conocimiento</MudMenuItem> }
        @if (_auth.TieneAcceso("/estudios-realizados")) { <MudMenuItem Href="/estudios-realizados">Estudios Realizados</MudMenuItem> }
        @if (_auth.TieneAcceso("/estudio-ac")) { <MudMenuItem Href="/estudio-ac">Estudio - Area</MudMenuItem> }
        @if (_auth.TieneAcceso("/beca")) { <MudMenuItem Href="/beca">Becas</MudMenuItem> }
        @if (_auth.TieneAcceso("/intereses_futuros")) { <MudMenuItem Href="/intereses_futuros">Intereses Futuros</MudMenuItem> }
        @if (_auth.TieneAcceso("/termino_clave")) { <MudMenuItem Href="/termino_clave">Terminos Clave</MudMenuItem> }
    </MudMenu>
}

@code {
    private bool PermiteAlguna(params string[] rutas) => rutas.Any(r => _auth.TieneAcceso(r));
}