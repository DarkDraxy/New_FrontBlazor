@inherits LayoutComponentBase
@implements IDisposable
@inject FrontBlazorTutorial.Services.AuthService _auth
@inject NavigationManager _nav

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_cargando)
{
    <MudLayout>
        <MudMainContent>
            <div class="d-flex justify-content-center align-items-center" style="min-height:100vh">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        </MudMainContent>
    </MudLayout>
}
else
{
    <MudLayout>
        <MudAppBar Color="Color.Surface" Elevation="0" Dense="true" Class="app-navbar">
           <MudText Typo="Typo.subtitle1" Class="app-brand me-6">
    <span class="brand-dot"></span> CRUD Facturas
</MudText> 

            <NavMenu />

            <MudSpacer />

            @if (_auth.EstaAutenticado)
            {
                <MudText Typo="Typo.body2" Class="me-3 text-muted">@(_auth.NombreUsuario ?? _auth.Usuario)</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="_Logout" Class="btn-ghost">
                    Cerrar sesion
                </MudButton>
            }
            else
            {
                <MudButton Href="/login" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" Class="btn-ghost">
                    Iniciar sesion
                </MudButton>
            }
        </MudAppBar>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.Large" Class="app-container">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _cargando = true;

    private readonly MudTheme _theme = new()
{
    PaletteLight = new PaletteLight
    {
        Primary = "#2563eb",
        PrimaryDarken = "#1d4ed8",
        Secondary = "#64748b",
        Background = "#ffffff",
        Surface = "#ffffff",
        AppbarBackground = "#ffffff",
        AppbarText = "#0f172a",
        TextPrimary = "#0f172a",
        TextSecondary = "#64748b",
        ActionDefault = "#475569",
        Divider = "#e2e8f0",
        LinesDefault = "#e2e8f0",
        TableLines = "#e2e8f0",
        TableStriped = "#f8fafc",
        Success = "#16a34a",
        Error = "#dc2626",
        Warning = "#d97706",
        Info = "#2563eb"
    }
};

    protected override void OnInitialized()
    {
        _nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _auth.Restaurar();
            _cargando = false;

            if (!_auth.EstaAutenticado && !_nav.Uri.Contains("/login"))
            {
                _nav.NavigateTo("/login");
                return;
            }

            if (_auth.DebeCambiarContrasena && !_nav.Uri.Contains("/cambiar-contrasena"))
            {
                _nav.NavigateTo("/cambiar-contrasena");
                return;
            }

            VerificarAcceso();
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        VerificarAcceso();
    }

    private void VerificarAcceso()
    {
        if (!_auth.EstaAutenticado) return;

        var uri = new Uri(_nav.Uri);
        var ruta = uri.AbsolutePath;

        if (ruta == "/" || ruta == "/login" || ruta == "/sin-acceso" ||
            ruta == "/cambiar-contrasena" || ruta == "/recuperar-contrasena")
            return;

        if (!_auth.TieneAcceso(ruta))
            _nav.NavigateTo("/sin-acceso");
    }

    private async Task _Logout()
    {
        await _auth.Logout();
        _nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        _nav.LocationChanged -= OnLocationChanged;
    }
}